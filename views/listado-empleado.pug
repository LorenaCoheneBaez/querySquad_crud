doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Listado de Empleados

    // Bootstrap
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

  body
    .container.mt-4

      h2 Listado de Empleados

      a.btn.btn-secondary.mb-3(href="/") Volver al inicio

      if query && query.msg === 'created'
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          | Empleado creado correctamente
          button.btn-close(type="button", data-bs-dismiss="alert")

      ul
        each empleado in empleados
          li.mb-3
            strong Nombre: #{empleado.nombre} #{empleado.apellido}
            br
            | DNI: #{empleado.dni}
            br
            | Empresa: #{empleado.nombreEmpresa}
            br

            a.btn.btn-primary.btn-sm(href=`/empleados/${empleado.id}/editar`) Editar

            form.d-inline(method="POST", action=`/empleados/${empleado.id}`)
              input(type="hidden", name="_method", value="DELETE")
              button.btn.btn-danger.btn-sm(
                type="submit",
                onclick="return confirm('¿Seguro que querés eliminar este empleado?')"
              ) Eliminar

      if empleados.length === 0
        p.text-muted No hay empleados registrados

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")