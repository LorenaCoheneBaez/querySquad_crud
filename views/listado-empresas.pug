doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Lista de Empresas

    // Bootstrap
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    // Bootstrap Icons
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

    // Estilos personalizados
    style.
      .bg-finance {
        background-color: #1e3a5f;
      }
      .btn-finance {
        background-color: #1e3a5f;
        color: white;
        border: none;
      }
      .btn-finance:hover {
        background-color: #16324a;
        color: white;
      }

  body
    // NAVBAR
    nav.navbar.navbar-expand-lg.navbar-dark.bg-finance
      .container-fluid
        a.navbar-brand(href="#") Query Squad
        .navbar-nav
          a.nav-link.active(href="/empresas") Lista de Empleados

    .container.mt-4

      // ALERTAS
      if query && query.msg
        .alert.alert-success.alert-dismissible.fade.show(role="alert")
          if query.msg === 'created'
            | Empresa creada correctamente
          else if query.msg === 'updated'
            | Empresa actualizada correctamente
          else if query.msg === 'deleted'
            | Empresa eliminada correctamente
          else if query.msg === 'status'
            | Estado actualizado correctamente

          button.btn-close(type="button", data-bs-dismiss="alert")

      h2 Lista de Empresas
      hr

      // BOTONES SUPERIORES
      .d-flex.justify-content-between.align-items-center.mb-3
        a.btn.btn-finance(href="/empresas/nueva")
          i.bi.bi-plus-lg
          |  Nueva Empresa

        .btn-group
          a.btn.btn-outline-primary(href="/empresas/listado-empresas-activas") Activas
          a.btn.btn-outline-secondary(href="/empresas/listado-empresas-inactivas") Inactivas

      // Filtro (decorativo)
      button.btn.btn-light.mb-3 Filtrar datos de empleados

      // TABLA
      table.table.table-bordered.table-hover
        thead.table-light
          tr
            th No
            th Cuit
            th Nombre
            th Dirección
            th Teléfono
            th Rubro
            th Estado
            th Acciones

        tbody
          each empresa, index in empresas
            tr
              td #{index + 1}
              td #{empresa.cuit}
              td #{empresa.nombre}
              td #{empresa.direccion}
              td #{empresa.telefono}
              td #{empresa.rubro}

              // ESTADO
              td
                if empresa.activo
                  span.badge.bg-success Activo
                else
                  span.badge.bg-secondary Inactivo

              // ACCIONES
              td(style="white-space: nowrap;")
                .d-flex.gap-2

                  // ✏️ EDITAR
                  a.btn.btn-primary.btn-sm(
                    href=`/empresas/${empresa.id}/editar`,
                    title="Editar empresa"
                  )
                    i.bi.bi-pencil

                  // 🔄 CAMBIAR ESTADO
                  form(method="POST", action=`/empresas/${empresa.id}/estado`)
                    input(type="hidden", name="_method", value="PUT")
                    button.btn.btn-sm(
                      type="submit",
                      class=empresa.activo ? 'btn-outline-danger' : 'btn-outline-success',
                      title=empresa.activo ? 'Desactivar empresa' : 'Activar empresa'
                    )
                      if empresa.activo
                        i.bi.bi-toggle-off
                      else
                        i.bi.bi-toggle-on

                  // 🗑 ELIMINAR
                  form(method="POST", action=`/empresas/${empresa.id}`)
                    input(type="hidden", name="_method", value="DELETE")
                    button.btn.btn-danger.btn-sm(
                      type="submit",
                      title="Eliminar empresa",
                      onclick="return confirm('¿Seguro que querés eliminar esta empresa?')"
                    )
                      i.bi.bi-trash

      if empresas.length === 0
        p.text-muted No hay empresas registradas.

    footer.text-center.mt-4.mb-3
      small © Query Squad 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")